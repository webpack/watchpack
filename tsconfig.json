{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",

    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,

    "types": ["node"],

    "rootDir": "./lib",
    "outDir": "./types",

    "allowJs": true,
    "checkJs": true,
    "strict": true,

    "alwaysStrict": true,
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "include": ["./lib/**/*"]
}
